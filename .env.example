# .env.example — copy to .env and fill in your values
# Never commit .env to version control.

# Required: Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=Bot your-token-here

# Optional: Comma-separated list of Discord user IDs that are considered bot
# owners. Owners bypass all command checks and can use owner-only commands.
# Example: OWNER_IDS=123456789012345678,987654321098765432
OWNER_IDS=

# Optional: Controls log verbosity. Uses the tracing-subscriber EnvFilter syntax.
# Examples:
#   RUST_LOG=info                                 — default, recommended for prod
#   RUST_LOG=discord_twilight=debug               — verbose for this crate only
#   RUST_LOG=discord_twilight=debug,serenity=warn — debug our code, quiet serenity
RUST_LOG=info

# Optional: Path to the file that stores the SHA-256 hash of the registered
# command set. Used for hash-based auto-registration on startup.
# Defaults to ".command_hash" next to the running binary if not set.
COMMAND_HASH_PATH=.command_hash

# ── Automatic Updates ──────────────────────────────────────────────────────────
# Enable automatic binary updates from GitHub Releases. When enabled, the bot
# periodically checks for new releases and installs them automatically. Requires
# write permissions to the bot's binary location. Defaults to false for safety.
AUTO_UPDATE_ENABLED=false

# Optional: How often to check for updates (in hours). Only used when
# AUTO_UPDATE_ENABLED is true. Defaults to 24 hours.
UPDATE_CHECK_HOURS=24

# Optional: GitHub repository for updates. Only change if using a fork.
# Defaults: RayZ3R0/discord-rumi
UPDATE_REPO_OWNER=RayZ3R0
UPDATE_REPO_NAME=discord-rumi

